<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE configuration
  PUBLIC "-//mybatis.org//DTD Config 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-config.dtd">
  <configuration>
  	<settings>
  		<setting name="mapUnderscoreToCamelCase" value="true"/>
  	</settings>
  	<typeAliases>
  		<typeAlias type="com.kh.delivery.model.dto.DeliMemberDto" alias="deliMember"/>
  		<typeAlias type="com.kh.delivery.model.dto.MenuDto" alias="menu"/>
  		<typeAlias type="com.kh.delivery.model.dto.OrderDto" alias="order"/>
  		<typeAlias type="com.kh.delivery.model.dto.RestaurantDto" alias="restaurant"/>
  	</typeAliases>
  	<environments default="deployment">
  		<environment id="deployment">
  			<transactionManager type="JDBC"/>
  			<dataSource type="POOLED">
  				<property name="driver" value="oracle.jdbc.driver.OracleDriver"/>
  				<property name="url" value="jdbc:oracle:thin:@127.0.0.1:1521:XE"/>
  				<property name="username" value="C##SJ"/>
  				<property name="password" value="SJ"/>
  			</dataSource>
  		</environment>
  	</environments>
  	<mappers>
  		<mapper resource="mappers/member-mapper.xml"/>
  		<mapper resource="mappers/restaurant-mapper.xml"/>
  		<mapper resource="mappers/order-mapper.xml"/>
  	</mappers>
  </configuration>